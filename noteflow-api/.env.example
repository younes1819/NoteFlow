DATABASE_URL=
JWT_SECRET=

# Firebase Admin (backend — verificar tokens de la app móvil)
# Opción A: JSON completo en una sola variable
FIREBASE_SERVICE_ACCOUNT_JSON=

# Opción B: variables separadas
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AWS S3 (presigned URLs para subida de imágenes)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# URL pública del bucket (opcional; si no se define se construye automáticamente)
AWS_S3_PUBLIC_URL=
