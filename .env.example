# Trello API (solo para scripts locales — no commitear valores reales)
TRELLO_API_KEY=
TRELLO_TOKEN=

# API backend (Expo — visible en el cliente, solo URL pública)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Firebase: descarga google-services.json y GoogleService-Info.plist desde
# la consola de Firebase y colócalos en la raíz del proyecto (ver .example).
